# Browser key (HTTP referrer restrictions) → js/site-secrets.js for live fetch in the page.
GOOGLE_PLACES_API_KEY=

# Server key (no referrer restriction, IP-only) → npm run reviews:fetch at build/CI.
GOOGLE_PLACES_SERVER_KEY=

# Referrers for browser key (Application restrictions):
#   https://www.kinesica.com.ar/
#   https://www.kinesica.com.ar/*
#   https://kinesica.com.ar/
#   https://kinesica.com.ar/*
#   http://localhost:*/*
#
# APIs: Places API (New) + Maps JavaScript API
