RewriteEngine On

# Canonical host: apex and bare domain → www
RewriteCond %{HTTP_HOST} ^kinesica\.com\.ar$ [NC]
RewriteRule ^ https://www.kinesica.com.ar%{REQUEST_URI} [R=301,L]

# HTTPS (when the request reaches Apache without TLS termination redirect)
RewriteCond %{HTTPS} off
RewriteRule ^ https://www.kinesica.com.ar%{REQUEST_URI} [R=301,L]

# Spanish home: /index.html → /
RewriteRule ^index\.html$ / [R=301,L]

# Canonical home for /en/, /fr/ and /pt/
RewriteRule ^en/index\.html$ /en/ [R=301,L]
RewriteRule ^fr/index\.html$ /fr/ [R=301,L]
RewriteRule ^pt/index\.html$ /pt/ [R=301,L]

# Legacy English filenames → /en/ (root only — avoid /en/foo_en → /en/en/foo)
RewriteCond %{REQUEST_URI} !^/en/
RewriteCond %{REQUEST_URI} !^/fr/
RewriteCond %{REQUEST_URI} !^/pt/
RewriteRule ^index_en\.html$ /en/ [R=301,L]
RewriteRule ^404_en\.html$ /en/404.html [R=301,L]
RewriteRule ^(.+)_en\.html$ /en/$1.html [R=301,L]

# Legacy French filenames → /fr/ (root only — avoid /fr/foo_fr → /fr/fr/foo)
RewriteCond %{REQUEST_URI} !^/en/
RewriteCond %{REQUEST_URI} !^/fr/
RewriteCond %{REQUEST_URI} !^/pt/
RewriteRule ^index_fr\.html$ /fr/ [R=301,L]
RewriteRule ^404_fr\.html$ /fr/404.html [R=301,L]
RewriteRule ^(.+)_fr\.html$ /fr/$1.html [R=301,L]

# Legacy CV PDFs → HTML pages
RewriteRule ^cv-norberto-brude\.pdf$ /cv.html [R=301,L]
RewriteRule ^cv-norberto-brude_en\.pdf$ /en/cv.html [R=301,L]
RewriteRule ^cv-norberto-brude_fr\.pdf$ /fr/cv.html [R=301,L]

# Typo slug fix: sacriiliaco → sacroiliaco (301)
RewriteRule ^dolor-sacriiliaco\.html$ /dolor-sacroiliaco.html [R=301,L]
RewriteRule ^en/dolor-sacriiliaco\.html$ /en/dolor-sacroiliaco.html [R=301,L]
RewriteRule ^fr/dolor-sacriiliaco\.html$ /fr/dolor-sacroiliaco.html [R=301,L]
RewriteRule ^pt/dolor-sacriiliaco\.html$ /pt/dolor-sacroiliaco.html [R=301,L]

ErrorDocument 404 /404-router.html

# Cache static images (SEO: Expires headers)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType image/vnd.microsoft.icon "access plus 1 year"
</IfModule>
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" "expr=%{HTTPS} == 'on'"
  <FilesMatch "\.(jpe?g|png|gif|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
    # mod_expires is inconsistent on Hostinger CDN for JPEG/PNG; set Expires explicitly for SEO audits.
    Header always set Expires "Tue, 21 Jun 2027 23:59:59 GMT"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>
